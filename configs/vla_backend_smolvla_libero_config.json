{
  "backend_name": "generic_vla_backend_smolvla_libero_v0",
  "server_url": "http://127.0.0.1:9200/predict",
  "health_url": "http://127.0.0.1:9200/health",
  "model_family": "smolvla",
  "model_id_or_path": "HuggingFaceVLA/smolvla_libero",
  "local_files_only": false,
  "timeout_sec": 15.0,
  "note": "First officially-registered SmolVLA checkpoint (policy_semantics/manifest.py) -- same Franka Panda embodiment and 6D-EE-delta+gripper action shape as this project's target, but CompatibilityGate still rejects production use until rotation_representation/reference_frame/gripper_convention/normalization scale are verified against the official LeRobot processor (see docs/vla_action_semantics.md). Use VLA_SMOKE_TEST_MODE=1 for shape-only pipeline smoke testing until then.",
  "image_encoding": {
    "format": "jpg_base64",
    "jpeg_quality": 90,
    "resize": {
      "enabled": true,
      "width": 224,
      "height": 224
    }
  },
  "request_schema": {
    "include_robot_state": true,
    "include_task_goal": true,
    "include_visual_observation": true,
    "include_target_positions": true
  },
  "action_schema": {
    "type": "delta_ee_7dof",
    "order": ["dx", "dy", "dz", "droll", "dpitch", "dyaw", "gripper"],
    "units": {
      "translation": "meters",
      "rotation": "radians"
    }
  },
  "action_postprocess": {
    "max_translation_step": 0.03,
    "max_rotation_step": 0.10,
    "gripper_threshold": 0.5,
    "clip_action": true
  },
  "fallback": {
    "enabled": true,
    "backend": "local-dummy"
  },
  "logging": {
    "save_raw_request": false,
    "save_raw_response": true,
    "save_debug_json": true
  }
}
