{
  "backend_name": "generic_vla_backend_openvla_v0",
  "server_url": "http://127.0.0.1:9300/predict",
  "health_url": "http://127.0.0.1:9300/health",
  "model_family": "openvla",
  "model_id_or_path": "openvla/openvla-7b",
  "local_files_only": false,
  "timeout_sec": 45.0,
  "image_encoding": {
    "format": "jpg_base64",
    "jpeg_quality": 90,
    "resize": {
      "enabled": true,
      "width": 224,
      "height": 224
    }
  },
  "request_schema": {
    "include_robot_state": true,
    "include_task_goal": true,
    "include_visual_observation": true,
    "include_target_positions": true
  },
  "action_schema": {
    "type": "delta_ee_7dof",
    "order": ["dx", "dy", "dz", "droll", "dpitch", "dyaw", "gripper"],
    "units": {
      "translation": "meters",
      "rotation": "radians"
    }
  },
  "action_postprocess": {
    "max_translation_step": 0.03,
    "max_rotation_step": 0.10,
    "gripper_threshold": 0.5,
    "clip_action": true
  },
  "fallback": {
    "enabled": true,
    "backend": "local-dummy"
  },
  "logging": {
    "save_raw_request": false,
    "save_raw_response": true,
    "save_debug_json": true
  },
  "note": "model_family=openvla always returns a structured openvla_action_adapter_required error in v0 -- see vla_adapters/openvla_adapter.py and docs/generic_vla_backend.md. This config exists so the interface/config shape is ready, not because OpenVLA execution works yet."
}
